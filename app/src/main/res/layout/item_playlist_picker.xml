<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Иконка плейлиста -->
        <TextView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="🎵"
            android:textSize="22sp"
            android:gravity="center"
            android:background="@drawable/bg_blob_blue"
            android:backgroundTint="#F0F0FF"/>

        <!-- Информация -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/tvPlaylistTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Название топа"
                android:fontFamily="@font/sonkobold"
                android:textColor="#000"
                android:textSize="15sp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvTrackCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 треков"
                android:fontFamily="@font/sonkoregular"
                android:textColor="#666680"
                android:textSize="12sp"
                android:paddingTop="2dp"/>

        </LinearLayout>


    </LinearLayout>

</androidx.cardview.widget.CardView>